# new-pawnshop-front environment variables
# Local dev reads .env.dev (see `yarn dev`). On Vercel, set these in Project Settings > Environment Variables.

# Backend API root. Point at the deployed backend, including the /api suffix.
NEXT_PUBLIC_API_BASE_URL=https://your-backend.onrender.com/api

# API version segment used by the client and the BFF proxy.
NEXT_PUBLIC_API_VERSION=v1

# Public site URL, used for SEO canonical/OpenGraph links.
NEXT_PUBLIC_SITE_URL=https://your-front.vercel.app

# External link shown in the "auctions" section.
NEXT_PUBLIC_FACEBOOK_AUCTIONS_URL=https://www.facebook.com/

# Stripe test publishable key. Live payment is currently a stub, so this is optional.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Server-only Stripe secret (unused while payments are stubbed).
STRIPE_SECRET_KEY=

# Timeout (ms) for the build-time locations fetch on /contact.
LOCATIONS_BUILD_TIMEOUT_MS=1500
